{
  "$schema": "../manifest.schema.json",
  "extends": "base/common.jsonc",
  "executable_package": "rtorrent",
  "target_glibc": "2.28",
  "packages": {
    "rtorrent": {
      "source": {
        "github": "rakshasa/rtorrent",
        "ref": "master"
      },
      "requires": ["rtorrent-libtorrent", "lua"]
    },
    "curl": {
      "source": {
        "github": "curl/curl",
        "ref": "refs/pull/22049/head"
      }
    },
    "rtorrent-libtorrent": {
      "source": {
        "github": "rakshasa/libtorrent",
        "ref": "master"
      },
      "requires": ["openssl", "zlib", "curl"]
    }
  }
}
