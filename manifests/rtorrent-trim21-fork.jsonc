{
  "$schema": "../manifest.schema.json",
  "extends": "base/common.jsonc",
  "executable_package": "rtorrent",
  "target_glibc": "2.28",
  "packages": {
    "rtorrent": {
      "source": {
        "github": "rakshasa/rtorrent",
        "ref": "master"
      },
      "requires": ["rtorrent-libtorrent", "lua"]
    },
    "rtorrent-libtorrent": {
      "source": {
        "git": "trim21@n5:projects/rtorrent-upstream/libtorrent/.git",
        "ref": "fix/poll-epoll-busy-loop"
      },
      "requires": ["openssl", "zlib", "curl"]
    }
  }
}
