{
  "$schema": "../manifest.schema.json",
  "extends": "base/common.jsonc",
  "executable_package": "rtorrent",
  "target_glibc": "2.28",
  "packages": {
    "rtorrent": {
      "source": {
        "github": "trim21/rtorrent-upstream",
        "ref": "feat/hash-error-message"
      },
      "requires": ["rtorrent-libtorrent", "lua"]
    },
    "rtorrent-libtorrent": {
      "source": {
        "github": "trim21/libtorrent",
        "ref": "feat/hash-error-number"
      },
      "requires": ["openssl", "zlib", "curl"]
    }
  }
}
