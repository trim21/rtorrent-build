{
  "$schema": "../manifest.schema.json",
  "extends": "common.jsonc",
  "target_glibc": "2.28",
  "packages": {
    "rtorrent": {
      "source": {
        "github": "rakshasa/rtorrent",
        "tag_range": ">=0.16,<0.17",
        "asset": "rtorrent-{version}.tar.gz"
      }
    },
    "rtorrent-libtorrent": {
      "source": {
        "github": "rakshasa/rtorrent",
        "tag_range": ">=0.16,<0.17",
        "asset": "libtorrent-{version}.tar.gz"
      }
    }
  }
}
