{
  "$defs": {
    "GenericRefSource": {
      "properties": {
        "git": {
          "title": "Git",
          "type": "string"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "git",
        "ref"
      ],
      "title": "GenericRefSource",
      "type": "object"
    },
    "GitHubRefSource": {
      "properties": {
        "github": {
          "title": "Github",
          "type": "string"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "github",
        "ref"
      ],
      "title": "GitHubRefSource",
      "type": "object"
    },
    "GitHubReleaseSource": {
      "properties": {
        "github": {
          "title": "Github",
          "type": "string"
        },
        "tag_range": {
          "title": "Tag Range",
          "type": "string"
        },
        "asset": {
          "title": "Asset",
          "type": "string"
        }
      },
      "required": [
        "github",
        "tag_range",
        "asset"
      ],
      "title": "GitHubReleaseSource",
      "type": "object"
    },
    "GitHubTagSource": {
      "properties": {
        "github": {
          "title": "Github",
          "type": "string"
        },
        "tag_range": {
          "title": "Tag Range",
          "type": "string"
        },
        "url_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url Template"
        }
      },
      "required": [
        "github",
        "tag_range"
      ],
      "title": "GitHubTagSource",
      "type": "object"
    },
    "GitSource": {
      "properties": {
        "url": {
          "title": "Url",
          "type": "string"
        },
        "sha": {
          "title": "Sha",
          "type": "string"
        }
      },
      "required": [
        "url",
        "sha"
      ],
      "title": "GitSource",
      "type": "object"
    },
    "LibInfo": {
      "properties": {
        "source": {
          "anyOf": [
            {
              "$ref": "#/$defs/GitHubTagSource"
            },
            {
              "$ref": "#/$defs/GitHubRefSource"
            },
            {
              "$ref": "#/$defs/GitHubReleaseSource"
            },
            {
              "$ref": "#/$defs/GenericRefSource"
            },
            {
              "$ref": "#/$defs/URLSource"
            },
            {
              "$ref": "#/$defs/GitSource"
            }
          ],
          "title": "Source"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        },
        "cxx_std": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cxx Std"
        },
        "requires": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requires"
        }
      },
      "required": [
        "source"
      ],
      "title": "LibInfo",
      "type": "object"
    },
    "URLSource": {
      "properties": {
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "title": "URLSource",
      "type": "object"
    }
  },
  "properties": {
    "packages": {
      "additionalProperties": {
        "$ref": "#/$defs/LibInfo"
      },
      "title": "Packages",
      "type": "object"
    },
    "extends": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extends"
    },
    "executable_package": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Executable Package"
    },
    "target_glibc": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Glibc"
    },
    "toolchain": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Toolchain"
    },
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    }
  },
  "required": [
    "packages"
  ],
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rtorrent-static/manifest.schema.json",
  "title": "Build Manifest",
  "description": "Build manifest for rtorrent-static variants"
}
