{
  "$defs": {
    "GitSource": {
      "properties": {
        "repo": {
          "title": "Repo",
          "type": "string"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        },
        "tag_range": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tag Range"
        }
      },
      "required": [
        "repo",
        "ref"
      ],
      "title": "GitSource",
      "type": "object"
    },
    "LibInfo": {
      "properties": {
        "source": {
          "$ref": "#/$defs/Source"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        },
        "cxx_std": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cxx Std"
        }
      },
      "required": [
        "source"
      ],
      "title": "LibInfo",
      "type": "object"
    },
    "Source": {
      "properties": {
        "git": {
          "anyOf": [
            {
              "$ref": "#/$defs/GitSource"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "url": {
          "anyOf": [
            {
              "$ref": "#/$defs/URLSource"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "Source",
      "type": "object"
    },
    "URLSource": {
      "properties": {
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "title": "URLSource",
      "type": "object"
    }
  },
  "properties": {
    "packages": {
      "additionalProperties": {
        "$ref": "#/$defs/LibInfo"
      },
      "title": "Packages",
      "type": "object"
    },
    "extends": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extends"
    },
    "target_glibc": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Glibc"
    },
    "toolchain": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Toolchain"
    }
  },
  "required": [
    "packages"
  ],
  "title": "Build Manifest",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rtorrent-static/manifest.schema.jsonc",
  "description": "Build manifest for rtorrent-static variants"
}
